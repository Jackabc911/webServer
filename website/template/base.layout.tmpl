{{define "base"}}
<!doctype html>
<html lang='en'>
<head>
    <meta charset='utf-8'>
    <title>{{template "title" .}} - my site</title>

    <!-- Ссылка на CSS стили и иконку сайта -->
    <link rel='stylesheet' href='/static/css/stylesheet.css'>
    <link rel='shortcut icon' href='/static/img/favicon.ico' type='image/x-icon'>

    <!--   Подключаем новый шрифт для сайта от Google Fonts -->
    <link rel='stylesheet' href='https://fonts.googleapis.com/css?family=Ubuntu+Mono:400,700'>
</head>
<body>
    <header>
        <h1><a href='/'>Home Page</a></h1>
    </header>
    <nav>
        <h3>Авторизуйтесь</h3>
    </nav>
    <div>
        <label for="username">Username:</label>
        <p><input type="text" id="username" name="username" /></p>
    </div>

    <div>
        <label for="pass">Password (8 characters minimum):</label>
        <p><input type="password" id="pass" name="password" minlength="8" required /></p>
    </div>

    <input type="submit" value="Sign in" />



    <form action="http://localhost:8080/api/v1/user/register" id="benderform">
        <input type="hidden" name="login" value="Admin1234">
        <input type="hidden" name="password" value="Admin123">

        <input type="submit" value="TEST">
    </form>

    
    
    <main>
        {{template "main" .}}
    </main>
    {{template "footer" .}}
    <!-- Подключаем JS чтобы сделать сайт более динамичным -->
    <script src="/static/js/script.js" type="text/javascript"></script>
</body>
</html>
{{end}}